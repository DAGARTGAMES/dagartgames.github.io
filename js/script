document.addEventListener('DOMContentLoaded', function() {
    
    
    const gamesModal = document.getElementById('gamesModal');
    const openGamesBtn = document.getElementById('openGamesBtn');
    const closeGamesBtn = document.querySelector('.closeGames');

    
    const textModal = document.getElementById('textModal');
    const openAboutBtn = document.getElementById('openAboutBtn');
    const openContactBtn = document.getElementById('openContactBtn');
    const closeTextBtn = document.querySelector('.closeText');
    
    const modalTitle = document.getElementById('modalTitle');
    const modalText = document.getElementById('modalText');

    
    function closeModal(modalElement) {
        modalElement.classList.add('closing');
        setTimeout(() => {
            modalElement.style.display = 'none';
            modalElement.classList.remove('closing');
        }, 400);
    }

    
    function transitionToGame() {
        
        gamesModal.classList.add('closing-for-game');
        
        
        setTimeout(() => {
            window.location.href = 'gameinfo.html';
        }, 600);
    }

   
    openGamesBtn.addEventListener('click', function(e) {
        e.preventDefault();
        gamesModal.classList.remove('closing');
        gamesModal.classList.remove('closing-for-game'); 
        gamesModal.style.display = 'flex';
    });

    closeGamesBtn.addEventListener('click', function() {
        closeModal(gamesModal);
    });

    window.addEventListener('click', function(e) {
        if (e.target === gamesModal) {
            closeModal(gamesModal);
        }
    });

    
    document.querySelectorAll('.game-card').forEach(function(card) {
        card.addEventListener('click', function() {
            transitionToGame();
        });
    });

    
    openAboutBtn.addEventListener('click', function(e) {
        e.preventDefault();
        modalTitle.innerText = "About Us";
        modalText.innerText = "2021 - 2026 DAG ART GAMES. Инди разработчик игр.";
        textModal.classList.remove('closing');
        textModal.style.display = 'flex';
    });

    openContactBtn.addEventListener('click', function(e) {
        e.preventDefault();
        modalTitle.innerText = "Contact Us";
        modalText.innerText = "Свяжитесь с нами по email: dagartgames@gmail.com";
        textModal.classList.remove('closing');
        textModal.style.display = 'flex';
    });

    closeTextBtn.addEventListener('click', function() {
        closeModal(textModal);
    });

    window.addEventListener('click', function(e) {
        if (e.target === textModal) {
            closeModal(textModal);
        }
    });
});