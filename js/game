document.addEventListener('DOMContentLoaded', function() {
    
    // Список всех скриншотов (добавьте сюда свои пути)
    const screenshots = [
        'img/screenshot_01.png',
        'img/screenshot_02.png',
        'img/screenshot_03.png',
        'img/screenshot_04.png',
        'img/screenshot_07.png',
        'img/screenshot_13.png',
        
    ];

    let currentIndex = 0; // Индекс текущей показываемой картинки
    const imgElement = document.getElementById('currentScreenshot');
    const prevBtn = document.querySelector('.prev-scr');
    const nextBtn = document.querySelector('.next-scr');

    // Функция для обновления картинки на экране
    function updateImage() {
        imgElement.src = screenshots[currentIndex];
    }

    // Кнопка "Вперед"
    nextBtn.addEventListener('click', function() {
        currentIndex++;
        if (currentIndex >= screenshots.length) {
            currentIndex = 0; // Если дошли до конца, переходим к первой
        }
        updateImage();
    });

    // Кнопка "Назад"
    prevBtn.addEventListener('click', function() {
        currentIndex--;
        if (currentIndex < 0) {
            currentIndex = screenshots.length - 1; // Если ушли в минус, идем к последней
        }
        updateImage();
    });

});